# =============================================================================
# .env.example — variáveis de ambiente (apenas segredos). Copie para `.env`.
# NUNCA commite o arquivo `.env` real. Chaves de API não vão em configs/.
# Prefixo/aninhamento: use `__` (ex.: MODEL__ACTIVE_MODEL=lightgbm).
# =============================================================================

# Token do Codecov (upload de cobertura no CI) — opcional localmente.
# CODECOV_TOKEN=

# Semente global (sobrescreve config.yaml se definida).
# RANDOM_SEED=42

# Este projeto usa dados públicos e não requer credenciais externas.
